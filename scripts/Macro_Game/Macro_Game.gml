function Macro_Game() {
	//Anything you want, must be a string.
#macro GAME_NAME ""

	//Anything you want, must be a string.
#macro GAME_AUTHOR ""

	//Anything you want, must be a string.
#macro GAME_VERSION ""

	//Anything you want, must be a string.
	//Can only contain letters numbers and underscores(_).
#macro GAME_SAVE_NAME ""

	//A GUID, must be a string.
	//Generate GUID here: https://www.guidgen.com/
#macro GAME_GUID ""


}
